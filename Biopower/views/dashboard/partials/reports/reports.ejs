<!-- RELATÓRIOS -->
<section class="adm-section" id="reports">
  <div class="adm-page-header">
    <div>
      <h1>Relatórios & Métricas</h1>
      <p>Análise estratégica de desempenho da operação.</p>
    </div>
    <button class="adm-btn adm-btn--ghost">
      <i class="fa-solid fa-download"></i> Exportar CSV
    </button>
  </div>
  <div class="adm-card adm-card--chart" style="margin-bottom: 1.5rem">
    <div class="adm-card-header"><h3>Vendas mensais — 2026</h3></div>
    <div class="adm-chart-placeholder">
      <div class="adm-chart-empty">
        <i class="fa-regular fa-chart-bar"></i>
        <p>Integre uma fonte de dados para exibir o gráfico</p>
      </div>
    </div>
  </div>
  <div class="adm-grid-2">
    <div class="adm-card adm-card--chart">
      <div class="adm-card-header"><h3>Vendas por categoria</h3></div>
      <div class="adm-chart-placeholder adm-chart-placeholder--sm">
        <div class="adm-chart-empty adm-chart-empty--sm">
          <i class="fa-solid fa-chart-pie"></i>
          <p>Sem dados</p>
        </div>
      </div>
    </div>
    <div class="adm-card adm-card--chart">
      <div class="adm-card-header">
        <h3>Novos clientes por mês</h3>
      </div>
      <div class="adm-chart-placeholder adm-chart-placeholder--sm">
        <div class="adm-chart-empty adm-chart-empty--sm">
          <i class="fa-solid fa-chart-line"></i>
          <p>Sem dados</p>
        </div>
      </div>
    </div>
  </div>
</section>
