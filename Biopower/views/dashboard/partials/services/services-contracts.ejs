<!-- SERVIÇOS CONTRATADOS -->
<section class="adm-section" id="services-contracts">
  <div class="adm-page-header">
    <div>
      <h1>Serviços contratados</h1>
      <p>Visualize solicitações e atualize status/observações.</p>
    </div>
  </div>

  <div class="adm-card" id="servicos-contratados-card">
    <div class="adm-card-header adm-card-header--between adm-contracts-header">
      <div class="adm-card-header-title">
        <h3>Lista de contratos</h3>
        <p>Controle centralizado com filtro por status.</p>
      </div>
      <div class="adm-contracts-filters">
        <div class="adm-filter-control">
          <label for="filtroStatusContrato">Status</label>
          <select id="filtroStatusContrato" class="adm-input adm-input--pill">
            <option value="">Todos</option>
            <% (statusServicos || []).forEach(function(st){ %>
              <option value="<%= st %>"><%= st %></option>
            <% }) %>
          </select>
        </div>
      </div>
    </div>

    <% if (!servicosContratados || servicosContratados.length === 0) { %>
      <div class="adm-empty-state" style="margin-bottom:0">
        <i class="fa-solid fa-clipboard-list"></i>
        <h2>Nenhum contrato de serviço</h2>
        <p>Quando os clientes contratarem serviços, você verá os registros aqui.</p>
      </div>
    <% } else { %>
    <div class="adm-table-wrap">
      <table class="adm-table adm-table--dense adm-table--contracts" id="tabela-contratos-servicos">
        <thead>
          <tr>
            <th>Cliente</th>
            <th>Serviço</th>
            <th class="col-status">Status</th>
            <th class="col-valor">Valor</th>
            <th class="col-date">Contratado em</th>
            <th class="col-obs">Obs.</th>
            <th class="col-actions">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% servicosContratados.forEach(function(c){ %>
          <tr data-contrato-id="<%= c.id %>" data-status="<%= c.status %>">
            <td>
              <div style="display:flex;flex-direction:column;gap:2px">
                <strong><%= c.clienteNome %></strong>
                <span style="font-size:0.85rem;color:var(--color-text-muted)"><%= c.clienteEmail %></span>
              </div>
            </td>
            <td>
              <div style="display:flex;flex-direction:column;gap:2px">
                <strong><%= c.servicoNome %></strong>
                <span style="font-size:0.85rem;color:var(--color-text-muted)"><%= c.servicoDescricao || "-" %></span>
              </div>
            </td>
            <td>
              <select class="adm-input adm-select-status js-contrato-status status-<%= c.status %>" data-id="<%= c.id %>">
                <% (statusServicos || []).forEach(function(st){ %>
                  <option value="<%= st %>" <%= c.status === st ? 'selected' : '' %>><%= st %></option>
                <% }) %>
              </select>
            </td>
            <td><strong>R$ <%= Number(c.servicoPreco || 0).toFixed(2) %></strong></td>
            <td>
              <span class="adm-date-main"><%= new Date(c.dataContratacao).toLocaleDateString('pt-BR') %></span>
              <span class="adm-date-sub">Atualizado: <%= new Date(c.dataAtualizacao || c.dataContratacao).toLocaleDateString('pt-BR') %></span>
            </td>
            <td>
              <input type="text" class="adm-input adm-input--ghost js-contrato-obs" placeholder="Obs. opcional" value="<%= c.observacoes || '' %>" />
            </td>
            <td>
              <div class="adm-actions">
                <button type="button" class="adm-btn adm-btn--ghost js-atualizar-contrato" data-id="<%= c.id %>">
                  <i class="fa-solid fa-rotate"></i> Atualizar
                </button>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</section>
