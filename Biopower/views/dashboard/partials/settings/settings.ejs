<!-- CONFIGURAÇÕES -->
<section class="adm-section" id="settings">
  <div class="adm-page-header">
    <div>
      <h1>Configurações</h1>
      <p>Parâmetros gerais do sistema.</p>
    </div>
  </div>
  <div class="adm-settings-grid">
    <div class="adm-card">
      <div class="adm-card-header">
        <h3><i class="fa-solid fa-store"></i> Dados da loja</h3>
      </div>
      <form class="adm-form">
        <div class="adm-form-group">
          <label>Nome da loja</label>
          <input
            type="text"
            value="Bio-Power Suplementos"
            class="adm-input"
          />
        </div>
        <div class="adm-form-group">
          <label>E-mail de contato</label>
          <input
            type="email"
            value="contato@biopower.com"
            class="adm-input"
          />
        </div>
        <div class="adm-form-group">
          <label>Telefone</label>
          <input
            type="text"
            placeholder="(00) 90000-0000"
            class="adm-input"
          />
        </div>
        <button type="button" class="adm-btn adm-btn--primary adm-btn--sm">
          Salvar alterações
        </button>
      </form>
    </div>
    <div class="adm-card">
      <div class="adm-card-header">
        <h3><i class="fa-solid fa-bell"></i> Notificações</h3>
      </div>
      <form class="adm-form">
        <label class="adm-toggle-row"
          ><span>Alertas de estoque crítico</span
          ><input type="checkbox" checked class="adm-toggle"
        /></label>
        <label class="adm-toggle-row"
          ><span>Novos pedidos por e-mail</span
          ><input type="checkbox" checked class="adm-toggle"
        /></label>
        <label class="adm-toggle-row"
          ><span>Relatório semanal automático</span
          ><input type="checkbox" class="adm-toggle"
        /></label>
      </form>
    </div>
  </div>
</section>
