<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bio-Power - Entrar</title>

    <link
      rel="shortcut icon"
      href="../assets/imgs/img-icon-site.png"
      type="image/x-icon"
    />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="../assets/css/screen/auth-screen.css" />
  </head>

  <body>
    <div class="container-fluid vh-100">
      <div class="row h-100">
        <!-- ─── Lado da imagem ─── -->
        <div
          class="col-md-6 d-none d-md-flex presentation-section flex-column justify-content-center align-items-center gap-4 p-5"
        >
          <div class="text-center text-white">
            <h2 class="fw-bold mb-2" style="font-size: 2rem">
              Bem-vindo de volta!
            </h2>
            <p class="mb-0 opacity-75" style="font-size: 1rem">
              Acesse sua conta e continue sua jornada de alta performance.
            </p>
          </div>
          <img
            src="../assets/imgs/img-auth-login.png"
            alt="Apresentação Bio-Power"
            class="img-fluid presentation-img"
          />
        </div>

        <!-- ─── Lado do formulário ─── -->
        <div
          class="col-md-6 d-flex flex-column justify-content-center align-items-center px-4 bg-white auth-form-side"
        >
          <div class="auth-card w-100">
            <!-- Logo -->
            <div class="text-center mb-4">
              <img
                src="../assets/imgs/img-logo-bio-power.png"
                id="img-logo"
                class="auth-logo"
                alt="Logo Bio-Power"
              />
              <p class="text-muted mt-2 mb-0" style="font-size: 0.9rem">
                Entre com suas credenciais para continuar
              </p>
              <script>
                document
                  .getElementById("img-logo")
                  .addEventListener("click", () => {
                    window.location.href = "/";
                  });
              </script>
            </div>

            <form method="POST" action="/login" id="loginForm" novalidate>
              <% if (error) { %>
                <div class="alert alert-danger mb-4" role="alert">
                  <%= error %>
                </div>
              <% } %>
              <!-- Email -->
              <div class="mb-3 auth-field-wrap">
                <div class="input-group auth-input-group">
                  <span class="input-group-text auth-input-icon">
                    <i class="fas fa-envelope"></i>
                  </span>
                  <div class="form-floating flex-grow-1">
                    <input
                      name="email"
                      type="email"
                      class="form-control auth-input"
                      id="email"
                      placeholder="email@exemplo.com"
                      autocomplete="email"
                      value="<%= form?.email %>"
                    />
                    <label for="email">Email</label>
                  </div>
                </div>
                <div id="error-email" class="auth-error-msg"></div>
              </div>

              <!-- Senha -->
              <div class="mb-3 auth-field-wrap">
                <div class="input-group auth-input-group">
                  <span class="input-group-text auth-input-icon">
                    <i class="fas fa-lock"></i>
                  </span>
                  <div class="form-floating flex-grow-1">
                    <input
                      name="password"
                      type="password"
                      class="form-control auth-input"
                      id="password"
                      placeholder="Senha"
                      autocomplete="current-password"
                    />
                    <label for="password">Senha</label>
                  </div>
                  <button
                    type="button"
                    class="btn auth-toggle-pass"
                    onclick="passwordShow('togglePassword', 'password')"
                    aria-label="Mostrar senha"
                  >
                    <i id="togglePassword" class="fas fa-eye"></i>
                  </button>
                </div>
                <div id="error-password" class="auth-error-msg"></div>
              </div>

              <!-- Lembrar / Esqueceu -->
              <div
                class="d-flex justify-content-between align-items-center mb-4"
              >
                <div class="form-check">
                  <input
                    type="checkbox"
                    class="form-check-input auth-check"
                    id="rememberMe"
                  />
                  <label
                    class="form-check-label text-muted small"
                    for="rememberMe"
                    >Lembre-se de mim</label
                  >
                </div>
                <a href="/forgot-password" class="auth-link small"
                  >Esqueceu a senha?</a
                >
              </div>

              <!-- Botão entrar -->
              <div class="d-grid mb-3">
                <button
                  type="submit"
                  class="btn btn-auth-primary py-2"
                  id="btn-login"
                >
                  <span class="btn-text">ENTRAR</span>
                  <span
                    class="btn-spinner spinner-border spinner-border-sm d-none ms-2"
                    role="status"
                  ></span>
                </button>
              </div>

              <!-- Link cadastro -->
              <p class="text-center text-muted small mb-4">
                Não tem uma conta?
                <a href="/register" class="auth-link fw-semibold"
                  >Criar conta gratuita</a
                >
              </p>

              <!-- Divisor -->
              <div class="auth-divider">
                <span>ou continue com</span>
              </div>

              <!-- Botões sociais -->
              <div class="d-flex gap-3 mt-3">
                <button type="button" class="btn auth-social-btn flex-fill">
                  <img
                    src="../assets/imgs/social/img-google.jpg"
                    alt="Google"
                    class="social-btn-icon"
                  />
                  <span>Google</span>
                </button>
                <button type="button" class="btn auth-social-btn flex-fill">
                  <img
                    src="../assets/imgs/social/img-facebook.png"
                    alt="Facebook"
                    class="social-btn-icon"
                  />
                  <span>Facebook</span>
                </button>
              </div>
              <p class="text-center text-muted small mt-4">
                Credenciais de teste: <strong>admin@biopower.com / admin123</strong>
                (painel admin) ou <strong>cliente@biopower.com / cliente123</strong> para clientes.
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>

    <script src="../assets/js/utils/generate-token.js"></script>
    <script src="../assets/js/toggle-password-login.js"></script>
    <script src="../assets/js/screens/login.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
