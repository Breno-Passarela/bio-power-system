<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bio-Power — Acesse sua conta</title>
    <link
      rel="shortcut icon"
      href="../assets/imgs/img-icon-site.png"
      type="image/x-icon"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="../assets/css/colors.css" />
    <link rel="stylesheet" href="../assets/css/screen/auth-choice.css" />
  </head>
  <body class="auth-page">
    <div class="auth-root">
      <!-- Painel esquerdo – marca -->
      <aside class="auth-brand">
        <div class="auth-brand-noise"></div>
        <div class="auth-brand-glow"></div>
        <div class="auth-brand-body">
          <img
            src="../assets/imgs/img-logo-bio-power.png"
            alt="Logo Bio-Power"
            class="auth-brand-logo"
          />

          <div class="auth-brand-copy">
            <p class="auth-brand-label">Plataforma de suplementação</p>
            <h1 class="auth-brand-heading">Performance<br />sem limites.</h1>
            <p class="auth-brand-sub">
              Produtos originais, entrega rápida e suporte especializado para
              quem leva o treino a sério.
            </p>
          </div>

          <ul class="auth-brand-stats">
            <li class="auth-brand-stat">
              <span class="auth-brand-stat-num">+10k</span>
              <span class="auth-brand-stat-label">Clientes ativos</span>
            </li>
            <li class="auth-brand-stat-divider"></li>
            <li class="auth-brand-stat">
              <span class="auth-brand-stat-num">4.9★</span>
              <span class="auth-brand-stat-label">Avaliação média</span>
            </li>
            <li class="auth-brand-stat-divider"></li>
            <li class="auth-brand-stat">
              <span class="auth-brand-stat-num">100%</span>
              <span class="auth-brand-stat-label">Seguro</span>
            </li>
          </ul>

          <ul class="auth-brand-features">
            <li>
              <span class="auth-brand-feature-icon"
                ><i class="fa-solid fa-shield-halved"></i
              ></span>
              <div>
                <strong>Compra protegida</strong>
                <span>Pagamento seguro e dados criptografados</span>
              </div>
            </li>
            <li>
              <span class="auth-brand-feature-icon"
                ><i class="fa-solid fa-truck-fast"></i
              ></span>
              <div>
                <strong>Entrega express</strong>
                <span>Despacho em até 24h para todo o Brasil</span>
              </div>
            </li>
            <li>
              <span class="auth-brand-feature-icon"
                ><i class="fa-solid fa-headset"></i
              ></span>
              <div>
                <strong>Suporte humano</strong>
                <span>Time disponível para te ajudar</span>
              </div>
            </li>
          </ul>
        </div>
      </aside>

      <!-- Painel direito – ações -->
      <section class="auth-panel">
        <div class="auth-card">
          <div class="auth-card-badge">Área do cliente</div>
          <h2 class="auth-card-title">Acesse sua conta</h2>
          <p class="auth-card-sub">Escolha como deseja continuar</p>

          <div class="auth-card-actions">
            <a class="auth-cta auth-cta--fill" href="/login">
              <i class="fa-solid fa-right-to-bracket"></i>
              <span>Fazer login</span>
              <i class="fa-solid fa-arrow-right auth-cta-arrow"></i>
            </a>
            <a class="auth-cta auth-cta--ghost" href="/register">
              <i class="fa-solid fa-user-plus"></i>
              <span>Criar conta gratuita</span>
            </a>
          </div>

          <div class="auth-card-trust">
            <i class="fa-solid fa-lock"></i>
            <span
              >Conexão segura &middot; SSL/TLS &middot; Dados protegidos</span
            >
          </div>

          <div class="auth-card-sep"><span>Precisa de ajuda?</span></div>

          <a class="auth-card-support" href="mailto:suporte@biopower.com">
            <i class="fa-solid fa-envelope"></i>
            suporte@biopower.com
          </a>

          <a class="auth-card-home" href="/">
            <i class="fa-solid fa-house"></i>
            <span>Voltar ao site</span>
          </a>
        </div>
      </section>
    </div>

    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/js/all.min.js"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    ></script>
  </body>
</html>
