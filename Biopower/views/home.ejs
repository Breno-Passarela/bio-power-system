<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bio-Power | Home</title>

  <link rel="shortcut icon" href="/assets/imgs/img-icon-site.png" type="image/x-icon">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@100..900&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    crossorigin="anonymous" referrerpolicy="no-referrer" />

  <link rel="stylesheet" href="/bootstrap-5.0.2-dist/css/bootstrap.min.css">

  <link rel="stylesheet" href="/assets/css/screen/home-screen.css" />
  <link rel="stylesheet" href="/assets/css/navbar.css" />
  <link rel="stylesheet" href="/assets/css/rodape.css" />
  <link rel="stylesheet" href="/assets/css/components/carousel/mini-carrousel.css">
</head>

<body>

  <!-- ===== CARROSSEL PRINCIPAL ===== -->
  <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4000">
    <div class="carousel-indicators">
      <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true"></button>
      <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
      <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
      <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="3"></button>
      <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="4"></button>
    </div>
    <div class="carousel-inner hero-carousel">
      <div class="carousel-item active">
        <img src="/assets/imgs/carrousel/banner.png" class="d-block w-100" alt="Banner 1">
      </div>
      <div class="carousel-item">
        <img src="/assets/imgs/carrousel/banner-3.png" class="d-block w-100" alt="Banner 3">
      </div>
      <div class="carousel-item">
        <img src="/assets/imgs/carrousel/banner-4.png" class="d-block w-100" alt="Banner 4">
      </div>
      <div class="carousel-item">
        <img src="/assets/imgs/carrousel/banner-5.png" class="d-block w-100" alt="Banner 5">
      </div>
      <div class="carousel-item">
        <img src="/assets/imgs/carrousel/banner-6.png" class="d-block w-100" alt="Banner 6">
      </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Anterior</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
      <span class="carousel-control-next-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Próximo</span>
    </button>
  </div>

  <!-- ===== STRIP DE BENEFÍCIOS ===== -->
  <div class="benefits-strip">
    <div class="benefit-item">
      <i class="fas fa-truck-fast"></i>
      <div>
        <strong>Frete Grátis</strong>
        <span>Acima de R$299</span>
      </div>
    </div>
    <div class="benefit-item">
      <i class="fas fa-shield-halved"></i>
      <div>
        <strong>Compra Segura</strong>
        <span>Pagamento protegido</span>
      </div>
    </div>
    <div class="benefit-item">
      <i class="fas fa-rotate-left"></i>
      <div>
        <strong>Troca Fácil</strong>
        <span>7 dias para trocar</span>
      </div>
    </div>
    <div class="benefit-item">
      <i class="fas fa-certificate"></i>
      <div>
        <strong>100% Original</strong>
        <span>Produtos certificados</span>
      </div>
    </div>
  </div>

  <!-- ===== CATEGORIAS ===== -->
  <section class="home-categories">
    <div class="home-section-header">
      <span class="home-tag">Encontre o que precisa</span>
      <h2>Categorias</h2>
    </div>

    <div class="categories-section">
      <button class="arrow left-arrow" onclick="scrollCategories(-1)" disabled>‹</button>
      <div id="categoriesCarousel" class="categories-track">
        <a href="/store" class="category category-item">
          <img src="/assets/imgs/categoria/Antioxidantes.png" alt="Antioxidantes" />
          <span>Antioxidantes</span>
        </a>
        <a href="/store" class="category category-item">
          <img src="/assets/imgs/categoria/Energéticos.png" alt="Energéticos" />
          <span>Energéticos</span>
        </a>
        <a href="/store" class="category category-item">
          <img src="/assets/imgs/categoria/Proteicos.png" alt="Proteicos" />
          <span>Proteicos</span>
        </a>
        <a href="/store" class="category category-item">
          <img src="/assets/imgs/categoria/indispo.png" alt="Em breve" />
          <span>Em breve</span>
        </a>
        <a href="/store" class="category category-item">
          <img src="/assets/imgs/categoria/indispo.png" alt="Em breve" />
          <span>Em breve</span>
        </a>
        <a href="/store" class="category category-item">
          <img src="/assets/imgs/categoria/indispo.png" alt="Em breve" />
          <span>Em breve</span>
        </a>
      </div>
      <button class="arrow right-arrow" onclick="scrollCategories(1)">›</button>
    </div>
  </section>

  <!-- ===== MAIS VENDIDOS ===== -->
  <section class="bestsellers">
    <div class="home-section-header">
      <span class="home-tag">Os preferidos dos clientes</span>
      <h2>Mais Vendidos</h2>
    </div>

    <div class="bestsellers-list">
      <% if (products && products.length) { %>
        <% products.slice(0, 8).forEach((product) => { %>
          <div class="home-product-card">
            <div class="home-product-img-wrap">
              <img src="<%= product.imagem %>" alt="<%= product.alt %>" />
            </div>
            <div class="home-product-info">
              <h3><%= product.nome %></h3>
              <p class="home-product-price">
                <%= product.preco %>
                <% if (product.desconto) { %>
                  <span class="home-product-desconto"><%= product.desconto %></span>
                <% } %>
              </p>
              <% if (product.credito) { %>
                <p class="home-product-credito"><%= product.credito %></p>
              <% } %>
              <div class="home-product-buttons">
                <button class="btn-comprar" type="button">Comprar</button>
                <button class="btn-carrinho" type="button" aria-label="Adicionar ao carrinho">
                  <i class="fa-solid fa-cart-shopping"></i>
                </button>
              </div>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <p class="no-products">Nenhum produto encontrado.</p>
      <% } %>
    </div>

    <div class="bestsellers-cta">
      <a href="/store" class="btn-ver-todos">Ver todos os produtos <i class="fas fa-arrow-right"></i></a>
    </div>
  </section>

  <!-- ===== POR QUE NOS ESCOLHER ===== -->
  <section class="home-why">
    <div class="home-section-header">
      <span class="home-tag">Nossa diferença</span>
      <h2>Por que escolher a Bio-Power?</h2>
    </div>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-icon"><i class="fas fa-flask"></i></div>
        <h4>Suplementos Testados</h4>
        <p>Trabalhamos apenas com marcas reconhecidas e produtos com formulação comprovada.</p>
      </div>
      <div class="why-card">
        <div class="why-icon"><i class="fas fa-dumbbell"></i></div>
        <h4>Para Todos os Objetivos</h4>
        <p>Do emagrecimento ao ganho de massa, temos o suplemento ideal para você.</p>
      </div>
      <div class="why-card">
        <div class="why-icon"><i class="fas fa-headset"></i></div>
        <h4>Suporte Especializado</h4>
        <p>Nossa equipe está disponível para orientar sua escolha e tirar dúvidas.</p>
      </div>
      <div class="why-card">
        <div class="why-icon"><i class="fas fa-tags"></i></div>
        <h4>Melhor Preço Garantido</h4>
        <p>Preços competitivos e promoções frequentes para você economizar mais.</p>
      </div>
    </div>
  </section>

  <script src="/bootstrap-5.0.2-dist/js/bootstrap.bundle.min.js"></script>
  <script src="/assets/js/navbar-script.js"></script>
  <script src="/assets/js/carrosel/mini-carrousel.js"></script>
</body>

</html>