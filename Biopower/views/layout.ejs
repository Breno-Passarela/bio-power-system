<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link
      rel="shortcut icon"
      href="/assets/imgs/img-icon-site.png"
      type="image/x-icon"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@100..900&display=swap"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />

    <link
      rel="stylesheet"
      href="../public/bootstrap-5.0.2-dist/css/bootstrap.min.css"
    />

    <link rel="stylesheet" href="../assets/css/navbar.css" />
    <link rel="stylesheet" href="../assets/css/rodape.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer></script>
  </head>

  <body>
    <div class="app-shell">
      <!-- Navbar -->
      <nav class="navbar">
        <!-- Logo -->
        <div class="navbar-logo">
          <a href="/" class="navbar-brand-link">
            <img
              src="/assets/imgs/img-icon-site.png"
              alt="Logo Bio-Power"
              class="navbar-logo-img"
            />
            <span>Bio-Power</span>
          </a>
        </div>

        <!-- Links centrais -->
        <div class="navbar-links" id="navbarLinks">
          <a href="/store">Loja</a>
          <% if (sessionUser?.role === "admin") { %>
            <a href="/dashboard/dashboard">Painel</a>
          <% } %>
          <a href="/services">Serviços</a>
          <a href="/about-us">Sobre Nós</a>
          <a href="#" id="abrirModalBtn">
            Categorias <i id="categoriaArrow" class="fas fa-chevron-down"></i>
          </a>
        </div>

        <!-- Ações (direita) -->
        <div class="navbar-actions">
          <!-- Botão de pesquisa (toggle overlay) -->
          <button
            class="navbar-icon-btn"
            id="searchToggleBtn"
            aria-label="Pesquisar"
          >
            <i class="fas fa-search"></i>
          </button>

          <div class="navbar-divider"></div>

          <!-- Carrinho com badge -->
          <a
            href="/shopping-cart"
            class="navbar-cart-link"
            aria-label="Carrinho"
          >
            <div class="cart-btn-wrap">
              <button class="cart-button">
                <i class="fa-solid fa-cart-shopping"></i>
              </button>
              <span class="cart-badge" id="cartBadge">0</span>
            </div>
          </a>

          <div class="navbar-divider"></div>

          <!-- Perfil / Login -->
          <div class="navbar-profile" id="navbarProfile">
            <% if (sessionUser) { %>
              <!-- Usuário logado: pill com inicial + nome + dropdown -->
              <div class="nb-user-pill">
                <div class="nb-user-pill-avatar nb-user-pill-avatar--<%= sessionUser.role %>">
                  <%= sessionUser.name.charAt(0).toUpperCase() %>
                </div>
                <div class="nb-user-pill-info">
                  <span class="nb-user-pill-name"><%= sessionUser.name.split(' ')[0] %></span>
                  <span class="nb-user-pill-role nb-user-pill-role--<%= sessionUser.role %>">
                    <% if (sessionUser.role === 'admin') { %>
                      <i class="fa-solid fa-shield-halved"></i> Admin
                    <% } else if (sessionUser.role === 'staff') { %>
                      <i class="fa-solid fa-briefcase"></i> Funcionário
                    <% } else { %>
                      <i class="fa-solid fa-user"></i> Cliente
                    <% } %>
                  </span>
                </div>
                <i class="fas fa-chevron-down nb-user-pill-arrow"></i>
              </div>

              <div class="profile-dropdown">
                <div class="profile-dropdown-header">
                  <div class="nb-dd-avatar nb-dd-avatar--<%= sessionUser.role %>">
                    <%= sessionUser.name.charAt(0).toUpperCase() %>
                  </div>
                  <div>
                    <span class="nb-dd-name"><%= sessionUser.name %></span>
                    <span class="nb-dd-email"><%= sessionUser.email %></span>
                  </div>
                </div>
                <div class="profile-dropdown-content">
                  <% if (sessionUser.role === 'admin' || sessionUser.role === 'staff') { %>
                    <a href="/dashboard/dashboard"><i class="fa-solid fa-chart-line"></i> Painel Admin</a>
                  <% } %>
                  <a href="/pedidos"><i class="fas fa-box"></i> Meus Pedidos</a>
                  <a href="#"><i class="fas fa-cog"></i> Configurações</a>
                  <div class="dropdown-divider"></div>
                  <a href="/logout" class="logout-item"><i class="fas fa-sign-out-alt"></i> Sair</a>
                </div>
              </div>
            <% } else { %>
              <!-- Não logado -->
              <a href="/auth" class="btn-login">
                <i class="fas fa-user"></i>
                <span>Acessar conta</span>
              </a>
            <% } %>
          </div>

          <!-- Hamburger mobile -->
          <button class="hamburger-menu" id="hamburgerMenu" aria-label="Menu">
            <i class="fas fa-bars"></i>
          </button>
        </div>
      </nav>

      <!-- Search Overlay (abaixo da navbar, full-width) -->
      <div class="search-overlay" id="searchOverlay">
        <div class="search-overlay-inner">
          <i class="fas fa-search search-overlay-icon"></i>
          <input
            type="search"
            class="search-overlay-input"
            id="searchOverlayInput"
            placeholder="Pesquisar produtos..."
            aria-label="Pesquisar produtos"
            autocomplete="off"
          />
          <button
            class="search-overlay-close"
            id="searchOverlayClose"
            aria-label="Fechar pesquisa"
          >
            <i class="fas fa-times"></i>
          </button>
        </div>
      </div>

      <!-- Mobile Screen -->
      <div class="mobile-menu-overlay" id="mobileMenuOverlay">
        <div class="mobile-menu-content">
          <button class="close-menu-button" id="closeMenuButton">
            <i class="fas fa-times"></i>
          </button>
          <div class="mobile-menu-links">
            <a href="/store">Loja</a>
            <a href="/services">Serviços</a>
            <a href="/about-us">Sobre Nós</a>
            <a href="/categorias">Categorias</a>
          </div>
          <div class="mobile-menu-auth">
            <% if (sessionUser) { %>
              <div class="mobile-auth-item">
                <div class="mobile-user-info">
                  <div class="mobile-user-avatar mobile-user-avatar--<%= sessionUser.role %>">
                    <%= sessionUser.name.charAt(0).toUpperCase() %>
                  </div>
                  <div>
                    <strong><%= sessionUser.name %></strong>
                    <span class="mobile-user-role mobile-user-role--<%= sessionUser.role %>">
                      <% if (sessionUser.role === 'admin') { %>
                        <i class="fa-solid fa-shield-halved"></i> Administrador
                      <% } else if (sessionUser.role === 'staff') { %>
                        <i class="fa-solid fa-briefcase"></i> Funcionário
                      <% } else { %>
                        <i class="fa-solid fa-user"></i> Cliente
                      <% } %>
                    </span>
                  </div>
                </div>
                <% if (sessionUser.role === 'admin' || sessionUser.role === 'staff') { %>
                  <a href="/dashboard/dashboard" class="mobile-settings-link"><i class="fa-solid fa-chart-line"></i> Painel Admin</a>
                <% } %>
                <a href="/pedidos" class="mobile-settings-link"><i class="fas fa-box"></i> Meus Pedidos</a>
                <a href="/logout" class="mobile-logout-button"><i class="fas fa-sign-out-alt"></i> Sair</a>
              </div>
            <% } else { %>
              <div class="mobile-auth-item">
                <a href="/auth" class="mobile-login-button">
                  <i class="fas fa-user-circle"></i> Fazer login / Criar conta
                </a>
              </div>
            <% } %>
          </div>
          <div class="mobile-menu-cart">
            <a href="/shopping-cart" class="mobile-cart-link">
              <i class="fa-solid fa-cart-shopping"></i> Carrinho
            </a>
          </div>
        </div>
      </div>

      <!-- Modal de Categorias -->
      <div id="modalCategorias" class="modal">
        <div class="modal-content">
          <div class="modal-header">
            <h2>Categorias</h2>
            <span class="fechar">&times;</span>
          </div>
          <div class="categorias-container">
            <div class="categoria-coluna">
              <h3>Proteína</h3>
              <ul>
                <li><a href="#">Whey Protein</a></li>
                <li><a href="#">Albumina</a></li>
                <li><a href="#">Caseína</a></li>
                <li><a href="#">Blend de Proteína</a></li>
                <li><a href="#">Proteína de Soja</a></li>
              </ul>
            </div>

            <div class="categoria-coluna">
              <h3>Aminoácidos</h3>
              <ul>
                <li><a href="#">BCAA</a></li>
                <li><a href="#">Creatina</a></li>
                <li><a href="#">Glutamina</a></li>
                <li><a href="#">Leucina</a></li>
              </ul>
            </div>

            <div class="categoria-coluna">
              <h3>Carboidratos</h3>
              <ul>
                <li><a href="#">Waxy Maize</a></li>
                <li><a href="#">Dextrose</a></li>
                <li><a href="#">Maltodextrina</a></li>
              </ul>
            </div>

            <div class="categoria-coluna">
              <h3>indispo</h3>
              <ul>
                <li><a href="#">Proteína de Arroz</a></li>
                <li><a href="#">Proteína da Ervilha</a></li>
                <li><a href="#">Aminoácidos indispo</a></li>
              </ul>
            </div>

            <div class="categoria-coluna">
              <h3>Vitaminas</h3>
              <ul>
                <li><a href="#">Complexo B</a></li>
                <li><a href="#">Multivitamínico</a></li>
                <li><a href="#">Carnitina</a></li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div><%- body %></div>

      <%- include('rodape') %>
    </div>

    <script src="../public/assets/js/navbar-script.js"></script>
  </body>
</html>
