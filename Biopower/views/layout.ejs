<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bio-Power | Home</title>

    <link
      rel="shortcut icon"
      href="../public/assets/imgs/img-icon-site.png"
      type="image/x-icon"
    />

    <!-- <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@100..900&display=swap"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    /> -->

    <link
      rel="stylesheet"
      href="../public/bootstrap-5.0.2-dist/css/bootstrap.min.css"
    />

    <link rel="stylesheet" href="../assets/css/navbar.css" />
  </head>

  <!-- Navbar -->
  <nav class="navbar">
    <div class="navbar-logo">
      <a href="/" style="text-decoration: none; color: #990000"> Bio-Power </a>
    </div>

    <div class="navbar-search" id="navbarSearch">
      <button class="search-icon-mobile" id="searchIconMobile">
        <i class="fas fa-search"></i>
      </button>
      <input
        type="search"
        placeholder="Pesquisar produtos..."
        aria-label="Pesquisar produtos"
        class="search-input-hidden"
        id="searchInputMobile"
      />
      <button class="search-submit-mobile" id="searchSubmitMobile">
        <i class="fas fa-paper-plane"></i>
      </button>
      <button class="search-close-mobile" id="searchCloseMobile">
        <i class="fas fa-times"></i>
      </button>
    </div>

    <button class="hamburger-menu" id="hamburgerMenu">
      <i class="fas fa-bars"></i>
    </button>

    <div class="navbar-links">
      <a href="src/pages/product-list.html">Loja</a>
      <a href="src/pages/sobre.html">Sobre Nós</a>
      <a href="#" id="abrirModalBtn">
        Categorias <i id="categoriaArrow" class="fas fa-chevron-down"></i>
      </a>
      <a href="./src/pages/list-product.html">Produtos</a>
    </div>
    <div class="button-cart-container">
      <a
        href="src/pages/shopping-cart.html"
        style="text-decoration: none; color: white"
      >
        <button class="cart-button">
          <i class="fa-solid fa-cart-shopping"> </i>
        </button>
      </a>
    </div>

    <div class="navbar-profile" id="navbarProfile">
      <img
        id="profileAvatar"
        class="navbar-avatar"
        alt="Avatar"
        style="display: none"
      />
      <a href="login" class="login-text" style="text-decoration: none">
        <span id="loginText" style="display: none"
          >Fazer login/Criar conta</span
        >
      </a>

      <div class="profile-dropdown" id="profileDropdown">
        <div class="profile-dropdown-content">
          <a href="#">Configuração</a>
          <a href="#" id="logoutBtn">Sair</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Mobile Screen -->
  <div class="mobile-menu-overlay" id="mobileMenuOverlay">
    <div class="mobile-menu-content">
      <button class="close-menu-button" id="closeMenuButton">
        <i class="fas fa-times"></i>
      </button>
      <div class="mobile-menu-links">
        <a href="src/pages/product-list.html">Loja</a>
        <a href="src/pages/sobre.html">Sobre Nós</a>
        <a href="/categorias.html">Categorias</a>
        <a href="./src/pages/list-product.html">Produtos</a>
      </div>
      <div class="mobile-menu-auth">
        <div
          id="mobileAuthLoggedOut"
          class="mobile-auth-item"
          style="display: none"
        >
          <a href="login" class="mobile-login-button">
            <i class="fas fa-user-circle"></i> Fazer login/Criar conta
          </a>
        </div>
        <div
          id="mobileAuthLoggedIn"
          class="mobile-auth-item"
          style="display: none"
        >
          <img id="mobileAvatar" class="mobile-avatar" alt="Avatar" />
          <a href="#" class="mobile-settings-link">Configuração</a>
          <button id="mobileLogoutBtn" class="mobile-logout-button">
            <i class="fas fa-sign-out-alt"></i> Sair
          </button>
        </div>
      </div>
      <div class="mobile-menu-cart">
        <button class="cart-button mobile-cart-button">
          <a
            href="./shopping-cart.html"
            style="text-decoration: none; color: black"
          >
            <i class="fa-solid fa-cart-shopping"></i> Carrinho
          </a>
        </button>
      </div>
    </div>
  </div>

  <!-- Modal de Categorias -->
  <div id="modalCategorias" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Categorias</h2>
        <span class="fechar">&times;</span>
      </div>
      <div class="categorias-container">
        <div class="categoria-coluna">
          <h3>Proteína</h3>
          <ul>
            <li><a href="#">Whey Protein</a></li>
            <li><a href="#">Albumina</a></li>
            <li><a href="#">Caseína</a></li>
            <li><a href="#">Blend de Proteína</a></li>
            <li><a href="#">Proteína de Soja</a></li>
          </ul>
        </div>

        <div class="categoria-coluna">
          <h3>Aminoácidos</h3>
          <ul>
            <li><a href="#">BCAA</a></li>
            <li><a href="#">Creatina</a></li>
            <li><a href="#">Glutamina</a></li>
            <li><a href="#">Leucina</a></li>
          </ul>
        </div>

        <div class="categoria-coluna">
          <h3>Carboidratos</h3>
          <ul>
            <li><a href="#">Waxy Maize</a></li>
            <li><a href="#">Dextrose</a></li>
            <li><a href="#">Maltodextrina</a></li>
          </ul>
        </div>

        <div class="categoria-coluna">
          <h3>indispo</h3>
          <ul>
            <li><a href="#">Proteína de Arroz</a></li>
            <li><a href="#">Proteína da Ervilha</a></li>
            <li><a href="#">Aminoácidos indispo</a></li>
          </ul>
        </div>

        <div class="categoria-coluna">
          <h3>Vitaminas</h3>
          <ul>
            <li><a href="#">Complexo B</a></li>
            <li><a href="#">Multivitamínico</a></li>
            <li><a href="#">Carnitina</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div><%- body %></div>
  <script src="../public/assets/js/navbar-script.js"></script>
</html>
