<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Bio-Power | Sobre Nós</title>

    <link
      rel="shortcut icon"
      href="/assets/imgs/img-icon-site.png"
      type="image/x-icon"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="../assets/css/screen/sobre-screen.css" />
    <link rel="stylesheet" href="../assets/css/navbar.css" />
    <link rel="stylesheet" href="../assets/css/rodape.css" />
  </head>

  <body>
    <!-- Hero -->
    <section class="sobre-hero">
      <div class="sobre-hero-overlay">
        <h1>Sobre a Bio-Power</h1>
        <p>Saúde, performance e confiança em cada produto</p>
        <a href="#contato" class="sobre-hero-btn">Fale Conosco</a>
      </div>
    </section>

    <!-- Sobre Nós -->
    <section class="sobre-intro">
      <div class="sobre-intro-text">
        <span class="sobre-tag">Nossa História</span>
        <h2>Quem Somos</h2>
        <p>
          A <strong>Bio-Power</strong> nasceu da paixão por saúde, bem-estar e
          performance. Somos uma loja especializada em suplementos alimentares
          de alta qualidade, comprometidos em oferecer produtos que realmente
          fazem a diferença na vida de nossos clientes.
        </p>
        <p>
          Com anos de experiência no mercado, nossa equipe é formada por
          profissionais qualificados que entendem as necessidades de atletas,
          praticantes de atividades físicas e pessoas que buscam uma vida mais
          saudável. Trabalhamos apenas com marcas reconhecidas e produtos
          certificados.
        </p>
        <p>
          Nosso compromisso vai além da venda: oferecemos orientação
          personalizada, preços justos e um atendimento que prioriza seu
          bem-estar e seus objetivos.
        </p>
      </div>
      <div class="sobre-intro-stats">
        <div class="stat-card">
          <span class="stat-number">5+</span>
          <span class="stat-label">Anos de Mercado</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">200+</span>
          <span class="stat-label">Produtos</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">10k+</span>
          <span class="stat-label">Clientes Atendidos</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">100%</span>
          <span class="stat-label">Produtos Certificados</span>
        </div>
      </div>
    </section>

    <!-- Valores -->
    <section class="sobre-valores">
      <div class="sobre-section-header">
        <span class="sobre-tag">O que nos move</span>
        <h2>Nossos Valores</h2>
      </div>
      <div class="valores-grid">
        <div class="valor-card">
          <div class="valor-icon"><i class="fas fa-certificate"></i></div>
          <h3>Qualidade</h3>
          <p>
            Selecionamos apenas produtos certificados das melhores marcas do
            mercado.
          </p>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><i class="fas fa-user-shield"></i></div>
          <h3>Confiança</h3>
          <p>
            Transparência e segurança em cada produto e em cada relação com o
            cliente.
          </p>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><i class="fas fa-heart"></i></div>
          <h3>Cuidado</h3>
          <p>
            Atendimento personalizado e humanizado para entender o seu objetivo.
          </p>
        </div>
        <div class="valor-card">
          <div class="valor-icon"><i class="fas fa-rocket"></i></div>
          <h3>Resultados</h3>
          <p>
            Focados em ajudar você a superar seus limites e alcançar suas metas.
          </p>
        </div>
      </div>
    </section>

    <!-- Diferenciais -->
    <section class="sobre-diferenciais">
      <div class="sobre-section-header">
        <span class="sobre-tag">Por que nos escolher</span>
        <h2>Nossos Diferenciais</h2>
      </div>
      <div class="diferenciais-list">
        <div class="diferencial-item">
          <i class="fas fa-truck-fast"></i>
          <div>
            <h4>Entrega Rápida</h4>
            <p>Envio para todo o Brasil com agilidade e segurança.</p>
          </div>
        </div>
        <div class="diferencial-item">
          <i class="fas fa-headset"></i>
          <div>
            <h4>Suporte Especializado</h4>
            <p>Equipe disponível para tirar dúvidas e orientar sua escolha.</p>
          </div>
        </div>
        <div class="diferencial-item">
          <i class="fas fa-shield-halved"></i>
          <div>
            <h4>Compra Segura</h4>
            <p>Ambiente 100% seguro com múltiplas formas de pagamento.</p>
          </div>
        </div>
        <div class="diferencial-item">
          <i class="fas fa-rotate-left"></i>
          <div>
            <h4>Política de Troca</h4>
            <p>Troca e devolução facilitada dentro do prazo legal.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contato -->
    <section class="sobre-contato" id="contato">
      <div class="sobre-section-header light">
        <span class="sobre-tag light-tag">Fale Conosco</span>
        <h2>Entre em Contato</h2>
        <p>Estamos prontos para te ajudar. Preencha o formulário abaixo.</p>
      </div>

      <div class="contato-wrapper">
        <div class="contato-info">
          <div class="contato-info-item">
            <i class="fas fa-location-dot"></i>
            <div>
              <h4>Endereço</h4>
              <p>Rua das Palmeiras, 123 – São Paulo, SP</p>
            </div>
          </div>
          <div class="contato-info-item">
            <i class="fas fa-phone"></i>
            <div>
              <h4>Telefone</h4>
              <p>(11) 99999-0000</p>
            </div>
          </div>
          <div class="contato-info-item">
            <i class="fas fa-envelope"></i>
            <div>
              <h4>E-mail</h4>
              <p>contato@biopower.com.br</p>
            </div>
          </div>
          <div class="contato-info-item">
            <i class="fas fa-clock"></i>
            <div>
              <h4>Horário</h4>
              <p>Seg – Sex: 8h às 18h<br />Sáb: 9h às 13h</p>
            </div>
          </div>
          <div class="contato-social">
            <a href="#" aria-label="Facebook"
              ><i class="fab fa-facebook-f"></i
            ></a>
            <a href="#" aria-label="Instagram"
              ><i class="fab fa-instagram"></i
            ></a>
            <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
            <a href="#" aria-label="WhatsApp"
              ><i class="fab fa-whatsapp"></i
            ></a>
          </div>
        </div>

        <form id="contactForm" class="contato-form" novalidate>
          <div
            id="successAlert"
            class="form-alert form-alert--success"
            role="alert"
            style="display: none"
          >
            <i class="fas fa-check-circle"></i> Mensagem enviada com sucesso! Em
            breve entraremos em contato.
          </div>

          <div class="form-grid">
            <div class="form-group">
              <label for="nome">Nome Completo *</label>
              <input
                type="text"
                id="nome"
                name="nome"
                placeholder="Seu nome"
                required
              />
              <span class="form-error" id="erro-nome"></span>
            </div>
            <div class="form-group">
              <label for="email">E-mail *</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="seu@email.com"
                required
              />
              <span class="form-error" id="erro-email"></span>
            </div>
            <div class="form-group">
              <label for="telefone">Telefone *</label>
              <input
                type="tel"
                id="telefone"
                name="telefone"
                placeholder="(00) 00000-0000"
                required
              />
              <span class="form-error" id="erro-telefone"></span>
            </div>
            <div class="form-group">
              <label for="assunto">Assunto *</label>
              <select id="assunto" name="assunto" required>
                <option value="">Selecione um assunto</option>
                <option value="duvida">Dúvida sobre produtos</option>
                <option value="pedido">Informações sobre pedido</option>
                <option value="sugestao">Sugestão</option>
                <option value="reclamacao">Reclamação</option>
                <option value="outro">Outro</option>
              </select>
              <span class="form-error" id="erro-assunto"></span>
            </div>
          </div>

          <div class="form-group form-group--full">
            <label for="mensagem">Mensagem *</label>
            <textarea
              id="mensagem"
              name="mensagem"
              rows="5"
              placeholder="Escreva sua mensagem aqui..."
              required
            ></textarea>
            <span class="form-error" id="erro-mensagem"></span>
          </div>

          <button type="submit" class="btn-enviar">
            <i class="fas fa-paper-plane"></i> Enviar Mensagem
          </button>
        </form>
      </div>
    </section>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
    <script src="../assets/js/navbar-script.js"></script>
    <script>
      // Máscara de telefone
      document
        .getElementById("telefone")
        .addEventListener("input", function (e) {
          let v = e.target.value.replace(/\D/g, "");
          if (v.length <= 10) {
            v = v.replace(/(\d{2})(\d{4})(\d{0,4})/, "($1) $2-$3");
          } else {
            v = v.replace(/(\d{2})(\d{5})(\d{0,4})/, "($1) $2-$3");
          }
          e.target.value = v;
        });

      // Validação e envio
      document
        .getElementById("contactForm")
        .addEventListener("submit", function (e) {
          e.preventDefault();

          const campos = ["nome", "email", "telefone", "assunto", "mensagem"];
          let valido = true;

          campos.forEach((id) => {
            const el = document.getElementById(id);
            const erro = document.getElementById("erro-" + id);
            if (!el.value.trim()) {
              el.classList.add("input-error");
              if (erro) erro.textContent = "Este campo é obrigatório.";
              valido = false;
            } else {
              el.classList.remove("input-error");
              if (erro) erro.textContent = "";
            }
          });

          if (!valido) return;

          const alert = document.getElementById("successAlert");
          alert.style.display = "flex";
          this.reset();

          setTimeout(() => {
            alert.style.display = "none";
          }, 5000);
        });
    </script>
  </body>
</html>
