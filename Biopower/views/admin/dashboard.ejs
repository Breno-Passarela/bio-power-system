<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bio-Power · Painel Administrativo</title>
    <link
      rel="shortcut icon"
      href="/assets/imgs/img-icon-site.png"
      type="image/x-icon"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/assets/css/colors.css" />
    <link rel="stylesheet" href="/assets/css/screen/admin-dashboard.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
  </head>
  <body class="adm">
    <!-- SIDEBAR -->
    <aside class="adm-sidebar" id="admSidebar">
      <div class="adm-sidebar-brand">
        <img
          src="/assets/imgs/img-logo-bio-power.png"
          alt="Bio-Power"
          class="adm-sidebar-logo"
        />
        <span class="adm-sidebar-brand-label">Bio-Power</span>
      </div>
      <div class="adm-sidebar-user">
        <div class="adm-sidebar-avatar">
          <i class="fa-solid fa-user-tie"></i>
        </div>
        <div class="adm-sidebar-user-info">
          <strong><%= user?.name || "Administrador" %></strong>
          <span>Administrador</span>
        </div>
      </div>
      <nav class="adm-nav">
        <p class="adm-nav-section-label">Principal</p>
        <a
          href="#overview"
          class="adm-nav-item adm-nav-item--active"
          data-section="overview"
        >
          <i class="fa-solid fa-chart-line"></i><span>Visão Geral</span>
        </a>
        <a href="#products" class="adm-nav-item" data-section="products">
          <i class="fa-solid fa-box-open"></i><span>Produtos</span
          ><span class="adm-nav-badge"><%= products.length %></span>
        </a>
        <a href="#categories" class="adm-nav-item" data-section="categories">
          <i class="fa-solid fa-tags"></i><span>Categorias</span>
        </a>
        <a href="#orders" class="adm-nav-item" data-section="orders">
          <i class="fa-solid fa-receipt"></i><span>Pedidos</span
          ><span class="adm-nav-badge adm-nav-badge--alert">07</span>
        </a>
        <a href="#stock" class="adm-nav-item" data-section="stock">
          <i class="fa-solid fa-warehouse"></i><span>Estoque</span>
        </a>
        <p class="adm-nav-section-label">Gestão</p>
        <a href="#users" class="adm-nav-item" data-section="users">
          <i class="fa-solid fa-users"></i><span>Usuários</span>
        </a>
        <a href="#services" class="adm-nav-item" data-section="services">
          <i class="fa-solid fa-calendar-check"></i><span>Serviços</span>
        </a>
        <a href="#coupons" class="adm-nav-item" data-section="coupons">
          <i class="fa-solid fa-ticket"></i><span>Cupons & Promoções</span>
        </a>
        <p class="adm-nav-section-label">Análise</p>
        <a href="#reports" class="adm-nav-item" data-section="reports">
          <i class="fa-solid fa-chart-bar"></i><span>Relatórios</span>
        </a>
        <p class="adm-nav-section-label">Sistema</p>
        <a href="#settings" class="adm-nav-item" data-section="settings">
          <i class="fa-solid fa-gear"></i><span>Configurações</span>
        </a>
        <a href="#permissions" class="adm-nav-item" data-section="permissions">
          <i class="fa-solid fa-shield-halved"></i><span>Permissões</span>
        </a>
      </nav>
      <a class="adm-sidebar-logout" href="/logout">
        <i class="fa-solid fa-right-from-bracket"></i
        ><span>Encerrar sessão</span>
      </a>
    </aside>
    <div class="adm-overlay" id="admOverlay"></div>

    <!-- SHELL -->
    <div class="adm-shell">
      <header class="adm-topbar">
        <div class="adm-topbar-left">
          <button
            class="adm-topbar-hamburger"
            id="admHamburger"
            aria-label="Abrir menu"
          >
            <i class="fa-solid fa-bars"></i>
          </button>
          <div class="adm-topbar-breadcrumb">
            <a href="/">Bio-Power</a>
            <i class="fa-solid fa-chevron-right"></i>
            <span id="breadcrumbCurrent">Visão Geral</span>
          </div>
        </div>
        <div class="adm-topbar-right">
          <div class="adm-notif-wrap" id="notifWrap">
            <button class="adm-topbar-icon-btn" id="notifBtn" title="Notificações" aria-expanded="false">
              <i class="fa-solid fa-bell"></i>
              <span class="adm-notif-count" id="notifCount">5</span>
            </button>

            <!-- PAINEL DE NOTIFICAÇÕES -->
            <div class="adm-notif-panel" id="notifPanel" hidden>
              <div class="adm-notif-panel-header">
                <span>Notificações</span>
                <button class="adm-notif-panel-mark-all" id="notifMarkAll">Marcar todas como lidas</button>
              </div>
              <ul class="adm-notif-list" id="notifList">
                <li class="adm-notif-item adm-notif-item--unread" data-id="1">
                  <div class="adm-notif-item-icon adm-notif-item-icon--order">
                    <i class="fa-solid fa-cart-shopping"></i>
                  </div>
                  <div class="adm-notif-item-body">
                    <p class="adm-notif-item-title">Novo pedido recebido</p>
                    <p class="adm-notif-item-desc">Pedido #4821 — Whey Protein + Creatina</p>
                    <span class="adm-notif-item-time">há 2 minutos</span>
                  </div>
                  <button class="adm-notif-item-read" title="Marcar como lida">×</button>
                </li>
                <li class="adm-notif-item adm-notif-item--unread" data-id="2">
                  <div class="adm-notif-item-icon adm-notif-item-icon--alert">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                  </div>
                  <div class="adm-notif-item-body">
                    <p class="adm-notif-item-title">Estoque crítico</p>
                    <p class="adm-notif-item-desc">Creatina Monohidratada 250g — apenas 3 un.</p>
                    <span class="adm-notif-item-time">há 15 minutos</span>
                  </div>
                  <button class="adm-notif-item-read" title="Marcar como lida">×</button>
                </li>
                <li class="adm-notif-item adm-notif-item--unread" data-id="3">
                  <div class="adm-notif-item-icon adm-notif-item-icon--user">
                    <i class="fa-solid fa-user-plus"></i>
                  </div>
                  <div class="adm-notif-item-body">
                    <p class="adm-notif-item-title">Novo usuário cadastrado</p>
                    <p class="adm-notif-item-desc">joãosilva@email.com acabou de se registrar</p>
                    <span class="adm-notif-item-time">há 1 hora</span>
                  </div>
                  <button class="adm-notif-item-read" title="Marcar como lida">×</button>
                </li>
                <li class="adm-notif-item adm-notif-item--unread" data-id="4">
                  <div class="adm-notif-item-icon adm-notif-item-icon--order">
                    <i class="fa-solid fa-truck"></i>
                  </div>
                  <div class="adm-notif-item-body">
                    <p class="adm-notif-item-title">Pedido enviado</p>
                    <p class="adm-notif-item-desc">Pedido #4819 foi marcado como enviado</p>
                    <span class="adm-notif-item-time">há 3 horas</span>
                  </div>
                  <button class="adm-notif-item-read" title="Marcar como lida">×</button>
                </li>
                <li class="adm-notif-item adm-notif-item--unread" data-id="5">
                  <div class="adm-notif-item-icon adm-notif-item-icon--alert">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                  </div>
                  <div class="adm-notif-item-body">
                    <p class="adm-notif-item-title">Estoque crítico</p>
                    <p class="adm-notif-item-desc">BCAA 2400 — apenas 2 un. disponíveis</p>
                    <span class="adm-notif-item-time">há 5 horas</span>
                  </div>
                  <button class="adm-notif-item-read" title="Marcar como lida">×</button>
                </li>
              </ul>
              <div class="adm-notif-panel-footer">
                <span id="notifEmpty" style="display:none">Nenhuma notificação pendente 🎉</span>
              </div>
            </div>
          </div>
          <a href="/" class="adm-topbar-site-link">
            <i class="fa-solid fa-arrow-up-right-from-square"></i
            ><span>Ver site</span>
          </a>
        </div>
      </header>

      <main class="adm-main">
        <!-- VISÃO GERAL -->
        <section class="adm-section adm-section--active" id="overview">
          <div class="adm-page-header">
            <div>
              <h1>Visão Geral</h1>
              <p>Indicadores estratégicos da operação em tempo real.</p>
            </div>
            <div class="adm-page-header-actions">
              <select class="adm-select">
                <option>Hoje</option>
                <option>Esta semana</option>
                <option selected>Este mês</option>
                <option>Este ano</option>
              </select>
            </div>
          </div>
          <div class="adm-kpi-grid">
            <div class="adm-kpi adm-kpi--primary">
              <div class="adm-kpi-icon">
                <i class="fa-solid fa-sack-dollar"></i>
              </div>
              <div class="adm-kpi-body">
                <p>Faturamento do mês</p>
                <strong>R$&nbsp;48.620</strong>
                <span class="adm-kpi-delta adm-kpi-delta--up"
                  ><i class="fa-solid fa-arrow-trend-up"></i> +14,3%</span
                >
              </div>
            </div>
            <div class="adm-kpi">
              <div class="adm-kpi-icon">
                <i class="fa-solid fa-basket-shopping"></i>
              </div>
              <div class="adm-kpi-body">
                <p>Pedidos do mês</p>
                <strong>312</strong>
                <span class="adm-kpi-delta adm-kpi-delta--up"
                  ><i class="fa-solid fa-arrow-trend-up"></i> +6,1%</span
                >
              </div>
            </div>
            <div class="adm-kpi">
              <div class="adm-kpi-icon"><i class="fa-solid fa-users"></i></div>
              <div class="adm-kpi-body">
                <p>Novos clientes</p>
                <strong>87</strong>
                <span class="adm-kpi-delta adm-kpi-delta--up"
                  ><i class="fa-solid fa-arrow-trend-up"></i> +9,5%</span
                >
              </div>
            </div>
            <div class="adm-kpi adm-kpi--alert">
              <div class="adm-kpi-icon">
                <i class="fa-solid fa-triangle-exclamation"></i>
              </div>
              <div class="adm-kpi-body">
                <p>Estoque crítico</p>
                <strong>03 itens</strong>
                <span class="adm-kpi-delta adm-kpi-delta--down"
                  ><i class="fa-solid fa-arrow-trend-down"></i> Requer
                  atenção</span
                >
              </div>
            </div>
            <div class="adm-kpi">
              <div class="adm-kpi-icon">
                <i class="fa-solid fa-percent"></i>
              </div>
              <div class="adm-kpi-body">
                <p>Taxa de conversão</p>
                <strong>3,8%</strong>
                <span class="adm-kpi-delta adm-kpi-delta--up"
                  ><i class="fa-solid fa-arrow-trend-up"></i> +0,4pp</span
                >
              </div>
            </div>
            <div class="adm-kpi">
              <div class="adm-kpi-icon">
                <i class="fa-solid fa-receipt"></i>
              </div>
              <div class="adm-kpi-body">
                <p>Ticket médio</p>
                <strong>R$&nbsp;155,90</strong>
                <span class="adm-kpi-delta adm-kpi-delta--neutral"
                  ><i class="fa-solid fa-minus"></i> Estável</span
                >
              </div>
            </div>
          </div>

          <div class="adm-charts-row">
            <div class="adm-card adm-card--chart">
              <div class="adm-card-header">
                <h3>Faturamento — Últimos 7 dias</h3>
              </div>
              <div class="adm-chart-placeholder">
                <div class="adm-chart-empty">
                  <i class="fa-regular fa-chart-bar"></i>
                  <p>
                    Integre uma fonte de dados para exibir o gráfico de receita
                  </p>
                </div>
              </div>
            </div>
            <div class="adm-card">
              <div class="adm-card-header"><h3>Pedidos por status</h3></div>
              <div class="adm-status-list">
                <div class="adm-status-item">
                  <span class="adm-status-dot adm-status-dot--warning"></span
                  ><span>Pendentes</span><strong>07</strong>
                </div>
                <div class="adm-status-item">
                  <span class="adm-status-dot adm-status-dot--info"></span
                  ><span>Em processamento</span><strong>14</strong>
                </div>
                <div class="adm-status-item">
                  <span class="adm-status-dot adm-status-dot--primary"></span
                  ><span>Enviados</span><strong>38</strong>
                </div>
                <div class="adm-status-item">
                  <span class="adm-status-dot adm-status-dot--success"></span
                  ><span>Concluídos</span><strong>253</strong>
                </div>
                <div class="adm-status-item">
                  <span class="adm-status-dot adm-status-dot--error"></span
                  ><span>Cancelados</span><strong>12</strong>
                </div>
              </div>
            </div>
          </div>

          <div class="adm-tables-row">
            <div class="adm-card">
              <div class="adm-card-header adm-card-header--between">
                <h3>Últimos pedidos</h3>
                <button
                  class="adm-btn adm-btn--ghost adm-btn--sm"
                  data-goto="orders"
                >
                  Ver todos
                </button>
              </div>
              <div class="adm-table-wrap">
                <table class="adm-table">
                  <thead>
                    <tr>
                      <th>#</th>
                      <th>Cliente</th>
                      <th>Valor</th>
                      <th>Status</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>#4501</td>
                      <td>Lucas Mendes</td>
                      <td>R$ 219,90</td>
                      <td>
                        <span class="adm-badge adm-badge--success"
                          >Concluído</span
                        >
                      </td>
                      <td>
                        <button class="adm-btn-icon">
                          <i class="fa-solid fa-eye"></i>
                        </button>
                      </td>
                    </tr>
                    <tr>
                      <td>#4502</td>
                      <td>Ana Paula</td>
                      <td>R$ 87,50</td>
                      <td>
                        <span class="adm-badge adm-badge--warning"
                          >Pendente</span
                        >
                      </td>
                      <td>
                        <button class="adm-btn-icon">
                          <i class="fa-solid fa-eye"></i>
                        </button>
                      </td>
                    </tr>
                    <tr>
                      <td>#4503</td>
                      <td>Rafael Costa</td>
                      <td>R$ 312,00</td>
                      <td>
                        <span class="adm-badge adm-badge--info">Enviado</span>
                      </td>
                      <td>
                        <button class="adm-btn-icon">
                          <i class="fa-solid fa-eye"></i>
                        </button>
                      </td>
                    </tr>
                    <tr>
                      <td>#4504</td>
                      <td>Carla Souza</td>
                      <td>R$ 59,90</td>
                      <td>
                        <span class="adm-badge adm-badge--error"
                          >Cancelado</span
                        >
                      </td>
                      <td>
                        <button class="adm-btn-icon">
                          <i class="fa-solid fa-eye"></i>
                        </button>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
            <div class="adm-card">
              <div class="adm-card-header adm-card-header--between">
                <h3>Produtos mais vendidos</h3>
                <button
                  class="adm-btn adm-btn--ghost adm-btn--sm"
                  data-goto="products"
                >
                  Ver catálogo
                </button>
              </div>
              <ul class="adm-rank-list">
                <li class="adm-rank-item">
                  <span class="adm-rank-pos">1</span>
                  <div class="adm-rank-info">
                    <strong>Whey Protein 900g</strong><span>142 unidades</span>
                  </div>
                  <span class="adm-rank-revenue">R$ 18.460</span>
                </li>
                <li class="adm-rank-item">
                  <span class="adm-rank-pos">2</span>
                  <div class="adm-rank-info">
                    <strong>Creatina Monohidratada</strong
                    ><span>98 unidades</span>
                  </div>
                  <span class="adm-rank-revenue">R$ 7.840</span>
                </li>
                <li class="adm-rank-item">
                  <span class="adm-rank-pos">3</span>
                  <div class="adm-rank-info">
                    <strong>BCAA 2400</strong><span>76 unidades</span>
                  </div>
                  <span class="adm-rank-revenue">R$ 5.320</span>
                </li>
                <li class="adm-rank-item">
                  <span class="adm-rank-pos">4</span>
                  <div class="adm-rank-info">
                    <strong>Pré-treino Extremo</strong><span>54 unidades</span>
                  </div>
                  <span class="adm-rank-revenue">R$ 4.860</span>
                </li>
              </ul>
            </div>
          </div>
        </section>

        <!-- PRODUTOS -->
        <section class="adm-section" id="products">
          <div class="adm-page-header">
            <div>
              <h1>Produtos</h1>
              <p>Gerencie todo o catálogo da Bio-Power. (<%= products.length %> produto<%= products.length !== 1 ? 's' : '' %>)</p>
            </div>
            <button class="adm-btn adm-btn--primary" onclick="document.getElementById('dialog-novo-produto').classList.add('adm-dialog--open')">
              <i class="fa-solid fa-plus"></i> Novo produto
            </button>
          </div>

          <% if (flash === 'produto-adicionado') { %>
          <div class="adm-flash adm-flash--success" id="flashMsg">
            <i class="fa-solid fa-circle-check"></i>
            Produto cadastrado com sucesso!
            <button class="adm-flash-close" onclick="document.getElementById('flashMsg').remove()">&#x2715;</button>
          </div>
          <% } %>

          <div class="adm-card">
            <div class="adm-table-wrap">
              <table class="adm-table">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Produto</th>
                    <th>Categoria</th>
                    <th>Marca</th>
                    <th>Sabor</th>
                    <th>Preço</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (products.length === 0) { %>
                  <tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--gray-500)">Nenhum produto cadastrado.</td></tr>
                  <% } %>
                  <% products.forEach(function(p, i) { %>
                  <tr>
                    <td><span class="adm-small-text"><%= i + 1 %></span></td>
                    <td>
                      <div class="adm-product-cell">
                        <div class="adm-product-thumb" style="background-image:url('<%= p.imagem %>');background-size:cover;background-position:center;"></div>
                        <div>
                          <strong><%= p.nome %></strong>
                        </div>
                      </div>
                    </td>
                    <td><span class="adm-badge adm-badge--info"><%= p.categoria %></span></td>
                    <td><%= p.marca %></td>
                    <td><%= p.sabor %></td>
                    <td><strong><%= p.preco %></strong></td>
                    <td>
                      <div class="adm-actions">
                        <form method="POST" action="/admin/products/delete/<%= i %>" style="display:inline" class="form-delete-product" data-nome="<%= p.nome %>">
                          <button type="submit" class="adm-btn-icon adm-btn-icon--danger" title="Excluir">
                            <i class="fa-solid fa-trash"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </section>

        <!-- DIALOG: NOVO PRODUTO -->
        <div class="adm-dialog" id="dialog-novo-produto">
          <div class="adm-dialog-backdrop" onclick="document.getElementById('dialog-novo-produto').classList.remove('adm-dialog--open')"></div>
          <div class="adm-dialog-panel" style="max-width:600px">
            <div class="adm-dialog-header">
              <h2><i class="fa-solid fa-box-open"></i> Novo produto</h2>
              <button class="adm-dialog-close" onclick="document.getElementById('dialog-novo-produto').classList.remove('adm-dialog--open')">&#x2715;</button>
            </div>
            <form method="POST" action="/admin/products" class="adm-form" enctype="multipart/form-data">
              <div class="adm-form-grid">
                <div class="adm-form-group adm-form-group--full">
                  <label>Nome do produto *</label>
                  <input type="text" name="nome" required placeholder="Ex: Whey Protein Baunilha 900g" class="adm-input">
                </div>
                <div class="adm-form-group">
                  <label>Categoria *</label>
                  <select name="categoria" required class="adm-input">
                    <option value="">Selecione…</option>
                    <option>Creatina</option>
                    <option>Whey</option>
                    <option>Pré-treino</option>
                    <option>Termogênico</option>
                    <option>BCAA</option>
                    <option>Glutamina</option>
                    <option>Hipercalórico</option>
                    <option>Vitaminas</option>
                    <option>Outros</option>
                  </select>
                </div>
                <div class="adm-form-group">
                  <label>Marca</label>
                  <input type="text" name="marca" placeholder="Ex: Growth Supplements" class="adm-input">
                </div>
                <div class="adm-form-group">
                  <label>Sabor</label>
                  <input type="text" name="sabor" placeholder="Ex: Chocolate" class="adm-input">
                </div>
                <div class="adm-form-group">
                  <label>Preço *</label>
                  <input type="text" name="preco" required placeholder="Ex: R$129,90" class="adm-input">
                </div>
                <div class="adm-form-group">
                  <label>Estoque inicial</label>
                  <input type="number" name="estoque" min="0" step="1" value="0" placeholder="Ex: 50" class="adm-input">
                </div>
                <div class="adm-form-group">
                  <label>Estoque mínimo</label>
                  <input type="number" name="estoqueMin" min="0" step="1" value="10" placeholder="Ex: 10" class="adm-input">
                </div>
                <div class="adm-form-group adm-form-group--full">
                  <label>Texto do crédito</label>
                  <input type="text" name="credito" placeholder="Ex: ou R$144,30 no cartão em até 6x de R$24,05" class="adm-input">
                </div>
                <div class="adm-form-group adm-form-group--full">
                  <label>Imagem do produto</label>
                  <input type="file" name="imagem" accept="image/jpeg,image/png,image/webp,image/gif" class="adm-input" id="inputImagemFile" onchange="previewImagem(this)">
                  <img id="previewImgProduto" src="" alt="" style="display:none;margin-top:8px;max-height:100px;border-radius:6px;border:1px solid #e5e7eb">
                  <small style="color:#6b7280;margin-top:4px;display:block">JPEG, PNG, WEBP ou GIF · máx. 5 MB</small>
